{
  "manifest_version": 3,
  "name": "LinkCaster",
  "version": "1.0.0",
  "description": "Convert share links to direct downloadable URLs and upload files to cloud storage providers.",
  "permissions": [
    "activeTab",
    "storage",
    "identity"
  ],
  "host_permissions": [
    "https://prnt.sc/*",
    "https://prntscr.com/*",
    "https://lightshot.com/*",
    "https://image.prntscr.com/*",
    "https://img.lightshot.app/*",
    "https://catbox.moe/*",
    "https://api.imgur.com/*",
    "https://freeimage.host/*",
    "https://www.flickr.com/*",
    "https://api.flickr.com/*",
    "https://up.flickr.com/*",
    "https://vgy.me/*",
    "https://gyazo.com/*",
    "https://upload.gyazo.com/*",
    "https://i.gyazo.com/*",
    "https://drive.google.com/*",
    "https://www.googleapis.com/*",
    "https://web-production-674b.up.railway.app/*",
    "https://*/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "extension_icon.png"
  },
  "icons": {
    "16": "extension_icon.png",
    "48": "extension_icon.png",
    "128": "extension_icon.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}
